#!/bin/sh
# shellcheck shell=sh
# Hermes gateway (OpenAI-compatible API server) supervised service.
#
# Runs only when API_SERVER_ENABLED is truthy. When disabled, the run
# script exits cleanly and the companion finish script returns 125 so
# s6-supervise leaves the slot in 'down' state instead of looping.
#
# Bind defaults to 127.0.0.1:8642 — the dashboard FastAPI app
# (web_server.py) reverse-proxies /v1/* to this loopback address, so
# external traffic stays gated behind the dashboard's auth/middleware
# stack and only the API_SERVER_KEY-protected /v1 surface is exposed.
#
# Sourcing /proc/1/environ instead of using #!/command/with-contenv sh:
# s6-overlay's with-contenv has been observed to drop env vars
# (API_SERVER_ENABLED, API_SERVER_KEY) on Railway, leaving this
# service unable to start the gateway. PID 1's environ is authoritative.

# shellcheck disable=SC1091
. /dev/stdin <<EOF
$(python3 - <<'PY'
import shlex
try:
    with open('/proc/1/environ', 'rb') as f:
        blob = f.read()
except OSError:
    blob = b''
for entry in blob.split(b'\x00'):
    if not entry or b'=' not in entry:
        continue
    name, _, value = entry.partition(b'=')
    try:
        name_s = name.decode('utf-8')
        value_s = value.decode('utf-8')
    except UnicodeDecodeError:
        continue
    if not name_s or not (name_s[0].isalpha() or name_s[0] == '_'):
        continue
    if not all(c.isalnum() or c == '_' for c in name_s):
        continue
    print(f"export {name_s}={shlex.quote(value_s)}")
PY
)
EOF

case "${API_SERVER_ENABLED:-}" in
    1|true|TRUE|True|yes|YES|Yes) ;;
    *)
        exit 0
        ;;
esac

cd /opt/data
# shellcheck disable=SC1091
. /opt/hermes/.venv/bin/activate

api_host="${API_SERVER_HOST:-127.0.0.1}"
api_port="${API_SERVER_PORT:-8642}"

# Pre-bind probe — same defensive pattern as the dashboard service.
# Avoids tight EADDRINUSE restart loops if the port is already taken.
if ! python3 -c "
import socket, sys
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
try:
    s.bind(('${api_host}', int('${api_port}')))
except OSError:
    sys.exit(1)
finally:
    s.close()
"; then
    echo "  hermes-gateway service: ${api_host}:${api_port} already bound — going idle." >&2
    exec sleep infinity
fi

exec s6-setuidgid hermes hermes gateway run
